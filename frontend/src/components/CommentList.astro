---
export const prerender = false;

import { actions } from 'astro:actions';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:5063';

const cookie = Astro.request.headers.get('cookie') || '';

const [commentsRes, sessionRes] = await Promise.all([
  fetch(`${API}/api/posts/${slug}/comments`),
  fetch(`${API}/api/auth/session`, { headers: { cookie } }),
]);

const { count = 0, comments = [] } = commentsRes.ok ? await commentsRes.json() : {};

let session = { authenticated: false, displayName: '', avatarUrl: '', provider: '' };
if (sessionRes.ok) {
  try {
    session = await sessionRes.json();
  } catch {
    // Invalid session response
  }
}

const result = Astro.getActionResult(actions.postComment);
const hasError = result?.error;

function relativeTime(dateStr: string): string {
  const now = Date.now();
  const then = new Date(dateStr).getTime();
  const seconds = Math.floor((now - then) / 1000);

  if (seconds < 60) return 'just now';
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  if (days < 30) return `${days}d ago`;
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<section class="comment-section" id="comments">
  <h2>Conversation <span class="comment-count">({count})</span></h2>
  <div class="accent-line" style="margin-bottom: 1.5rem;"></div>

  {hasError && (
    <div class="comment-error" role="alert">
      {result.error.message || 'Something went wrong. Please try again.'}
    </div>
  )}

  {session.authenticated ? (
    <form class="comment-compose" method="POST" action={actions.postComment}>
      <div class="comment-compose-user">
        <img src={session.avatarUrl || '/default-avatar.svg'} alt="" width="24" height="24" />
        <span>{session.displayName}</span>
      </div>
      <input type="hidden" name="slug" value={slug} />
      <textarea
        name="text"
        placeholder="Share your thoughts..."
        rows={3}
        maxlength={2000}
        required
        aria-label="Write a comment"
      ></textarea>
      <button type="submit">Post comment</button>
    </form>
  ) : (
    <div class="comment-signin">
      <p>Join the conversation</p>
      <div class="oauth-buttons">
        <a
          href={`${API}/api/auth/oauth/github?returnUrl=${Astro.url.href}#comments`}
          class="oauth-button"
        >
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href={`${API}/api/auth/oauth/google?returnUrl=${Astro.url.href}#comments`}
          class="oauth-button"
        >
          <svg viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Google
        </a>
      </div>
    </div>
  )}

  {comments.map((c: any) => (
    <div class="comment">
      <img src={c.avatarUrl || '/default-avatar.svg'} alt="" width="32" height="32" loading="lazy" />
      <div class="comment-meta">
        <span class="comment-name">{c.displayName}</span>
        <span class="comment-provider-badge">{c.provider}</span>
        <time datetime={c.createdAt}>{relativeTime(c.createdAt)}</time>
      </div>
      <p class="comment-text">{c.text}</p>
    </div>
  ))}

  {comments.length === 0 && !hasError && (
    <p class="comment-empty">No comments yet. Be the first to share your thoughts.</p>
  )}
</section>
