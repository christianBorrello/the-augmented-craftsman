---
interface Props {
  tag: string;
  count?: number;
  size?: 'sm' | 'md';
  linked?: boolean;
}

const { tag, count, size = 'sm', linked = false } = Astro.props;

const tagColors: Record<string, string> = {
  'tdd': 'bg-amber-600/10 text-amber-600 dark:bg-amber-400/10 dark:text-amber-400 border-amber-600/20 dark:border-amber-400/20',
  'clean-architecture': 'bg-emerald-600/10 text-emerald-600 dark:bg-emerald-400/10 dark:text-emerald-400 border-emerald-600/20 dark:border-emerald-400/20',
  'ddd': 'bg-violet-600/10 text-violet-600 dark:bg-violet-400/10 dark:text-violet-400 border-violet-600/20 dark:border-violet-400/20',
  'solid': 'bg-sky-600/10 text-sky-600 dark:bg-sky-400/10 dark:text-sky-400 border-sky-600/20 dark:border-sky-400/20',
  'refactoring': 'bg-rose-600/10 text-rose-600 dark:bg-rose-400/10 dark:text-rose-400 border-rose-600/20 dark:border-rose-400/20',
  'csharp': 'bg-indigo-600/10 text-indigo-600 dark:bg-indigo-400/10 dark:text-indigo-400 border-indigo-600/20 dark:border-indigo-400/20',
  'testing': 'bg-teal-600/10 text-teal-600 dark:bg-teal-400/10 dark:text-teal-400 border-teal-600/20 dark:border-teal-400/20',
  'xp': 'bg-orange-600/10 text-orange-600 dark:bg-orange-400/10 dark:text-orange-400 border-orange-600/20 dark:border-orange-400/20',
};

const slug = tag.toLowerCase().replace(/\s+/g, '-');

const colorClass = tagColors[slug] ||
  'bg-(--color-bg-surface) text-(--color-text-muted) border-(--color-border)';

const sizeClass = size === 'md'
  ? 'px-3 py-1.5 text-sm'
  : 'px-2 py-0.5 text-xs';

const Tag = linked ? 'a' : 'span';
---

<Tag
  class:list={[
    'inline-flex items-center gap-1.5 rounded-md border font-mono transition-all duration-200',
    colorClass,
    sizeClass,
    linked && 'hover:scale-105',
  ]}
  {...linked ? { href: `/tags/${slug}` } : {}}
>
  {tag}
  {count !== undefined && (
    <span class="opacity-60">{count}</span>
  )}
</Tag>
