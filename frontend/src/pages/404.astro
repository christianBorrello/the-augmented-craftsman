---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — The Augmented Craftsman">
  <section class="max-w-wide mx-auto px-6 md:px-10 py-24 md:py-32 flex flex-col items-center text-center">
    <div class="w-16 h-16 relative mb-8">
      <div class="absolute inset-0 border-2 border-[var(--color-accent)] rounded-sm rotate-12"></div>
      <div class="absolute inset-1 border border-[var(--color-text-muted)] rounded-sm -rotate-6 opacity-40"></div>
      <div class="absolute inset-2 border border-[var(--color-border)] rounded-sm rotate-3 opacity-20"></div>
    </div>

    <p class="font-mono text-sm text-[var(--color-accent)] tracking-wider uppercase mb-4">404</p>

    <h1 class="font-display text-3xl md:text-4xl font-semibold tracking-tight mb-4">
      Page not found
    </h1>

    <p class="text-[var(--color-text-muted)] max-w-md mb-10 text-body-sm leading-relaxed">
      The page you're looking for doesn't exist, or it was moved somewhere else.
      Like a test without an assertion — it leads nowhere.
    </p>

    <a
      href="/"
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-accent)] text-white text-sm font-medium rounded-lg hover:bg-[var(--color-accent-hover)] transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Back to home
    </a>
  </section>
</BaseLayout>
