---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import TagBadge from '../../components/TagBadge.astro';
import { fetchTags } from '../../data/api';

const allTags = await fetchTags();
---

<BaseLayout title="Topics — The Augmented Craftsman" description="Browse posts by topic: TDD, DDD, Clean Architecture, SOLID, and more.">

  <Hero
    title="Topics"
    subtitle="Explore by discipline. Each tag represents a practice I study and apply daily."
  />

  <section class="px-6 md:px-10 max-w-wide mx-auto">
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 stagger">
      {allTags.map(({ name, slug, postCount }) => (
        <a
          href={`/tags/${slug}`}
          class="group flex items-center justify-between p-5 rounded-xl border border-(--color-border) transition-all duration-300 hover:border-(--color-accent)/40 hover:shadow-lg hover:shadow-(--color-accent)/5 animate-fade-up"
        >
          <div class="flex items-center gap-3">
            <TagBadge tag={name} size="md" />
          </div>
          <div class="flex items-center gap-2">
            <span class="text-body-sm text-(--color-text-muted) font-mono">
              {postCount} {postCount === 1 ? 'post' : 'posts'}
            </span>
            <svg class="w-4 h-4 text-(--color-text-muted) group-hover:text-(--color-accent) group-hover:translate-x-1 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>
