---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import PostCard from '../../components/PostCard.astro';
import { fetchTags, fetchPostsByTag } from '../../data/api';

export async function getStaticPaths() {
  const tags = await fetchTags();
  return tags.map(({ name, slug }) => ({
    params: { tag: slug },
    props: { tagName: name },
  }));
}

const { tag } = Astro.params;
const { tagName } = Astro.props;
const tagPosts = await fetchPostsByTag(tag!);
---

<BaseLayout title={`${tagName} — The Augmented Craftsman`} description={`Posts about ${tagName}`}>

  <Hero
    title={tagName}
    subtitle={`${tagPosts.length} ${tagPosts.length === 1 ? 'post' : 'posts'} exploring this discipline.`}
  />

  <section class="px-6 md:px-10 max-w-wide mx-auto">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
      {tagPosts.map((post) => (
        <div class="animate-fade-up">
          <PostCard {...post} />
        </div>
      ))}
    </div>
  </section>

  <div class="mt-12 px-6 md:px-10 max-w-wide mx-auto">
    <a href="/tags" class="inline-flex items-center gap-2 text-body-sm font-mono text-(--color-accent) hover:underline">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      All topics
    </a>
  </div>

</BaseLayout>
