---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Crafting software with intention — TDD, Clean Architecture, DDD, and the pursuit of elegant code.', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="api-base" content={import.meta.env.PUBLIC_API_URL || 'http://localhost:5063'} />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--color-bg)] text-[var(--color-text)]">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      })();
      document.documentElement.classList.toggle('dark', theme === 'dark');

      window.__visitorId = localStorage.getItem('visitor_id');
      if (!window.__visitorId) {
        window.__visitorId = crypto.randomUUID();
        localStorage.setItem('visitor_id', window.__visitorId);
      }
    </script>
  </body>
</html>
